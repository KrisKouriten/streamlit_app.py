# Copy to .env.local for local dev, or set these in Vercel project settings.

# Postgres connection string from Neon / Supabase / Vercel Postgres.
DATABASE_URL=postgres://user:password@host:5432/dbname

# A long random string for signing login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
